# Telegram Bot Configuration
# Get your bot token from @BotFather on Telegram
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here

# LLM Configuration (Agnostic Backend)
# Supported options: openai, gemini, anthropic, openai-compatible
LLM_PROVIDER=openai

# Model Name to use (e.g. gpt-4o-mini, gemini-2.5-flash, claude-3-5-sonnet-20241022)
LLM_MODEL=gpt-4o-mini

# API Key for the chosen LLM Provider
LLM_API_KEY=your_llm_api_key_here

# Base URL for custom endpoints (Optional, e.g. for Ollama, Groq, OpenRouter, DeepSeek)
LLM_BASE_URL=

# LTA DataMall Configuration (Optional)
# Get your AccountKey from datamall.lta.gov.sg
# If left blank or omitted, the bot will use realistic simulated bus arrival times.
LTA_ACCOUNT_KEY=
LTA_SDK_KEY=

# OneMap Configuration (Optional, for live transit routing and geocoding)
# Register a free developer account at onemap.gov.sg
ONEMAP_EMAIL=
ONEMAP_PASSWORD=

